# Pipecat demo env vars.
# Copy this file to `.env` and fill in real values before running pipecat_demo.py.

# --- Speech-to-Text -----------------------------------------------------------
DEEPGRAM_API_KEY=

# --- LLM ----------------------------------------------------------------------
# Provider: "groq" (default, the brief's choice), "openai", or "anthropic".
LLM_PROVIDER=groq
LLM_API_KEY=
# Optional explicit model override. Sensible defaults are used if unset:
#   groq      -> llama-3.1-8b-instant
#   openai    -> gpt-4o-mini
#   anthropic -> claude-3-5-haiku-latest
LLM_MODEL=llama-3.1-8b-instant

# --- Megakernel TTS -----------------------------------------------------------
# Optional overrides. Defaults match the canonical Qwen3-TTS-12Hz-1.7B-CustomVoice.
MEGAKERNEL_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
MEGAKERNEL_MODEL_PATH=/workspace/qwen3-tts-1.7b
MEGAKERNEL_SPEAKER=ryan
MEGAKERNEL_DEVICE=cuda
# Set to 1 to run the Pipecat pipeline against the silence stub (no GPU needed).
MEGAKERNEL_STUB=0
# HuggingFace token, required when pulling gated Qwen3-TTS weights.
HF_TOKEN=

# --- Transport ----------------------------------------------------------------
# INPUT_MODE selects between mic-in/speaker-out and file-in/wav-out.
#   mic  -> LocalAudioInputTransport + LocalAudioOutputTransport (workstation).
#   file -> WavFileInputProcessor + AudioBufferProcessor -> WAV (headless GPU).
INPUT_MODE=mic
# Required when INPUT_MODE=file. Must be 16-bit PCM mono WAV.
INPUT_WAV=/workspace/samples/user_utterance.wav
# Output WAV path (file mode only). Written at 24 kHz mono.
OUTPUT_WAV=/workspace/samples/bot_response.wav

# Logging verbosity for loguru (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
